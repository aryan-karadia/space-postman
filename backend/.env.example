# ─── Space Postman Backend ─── Environment Variables ───
# Copy this file to .env and fill in the values.

# S3 bucket name for letter storage
S3_BUCKET_NAME=space-postman-letters

# AWS region
AWS_REGION=us-east-1

# Allowed CORS origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000

# Public frontend URL (for generating shareable links)
PUBLIC_FRONTEND_URL=http://localhost:3000
